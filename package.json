{
  "name": "youtube-dj-mixer",
  "version": "1.0.0",
  "description": "A dual-deck YouTube DJ Mixer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "package-win": "electron-packager . \"YouTube DJ Mixer\" --platform=win32 --arch=x64 --out=dist --overwrite"
  },
  "build": {
    "appId": "com.youtube.dj.mixer",
    "productName": "YouTube DJ Mixer",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "asar": true,
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false
    }
  },
  "author": "User",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "yt-search": "^2.13.1"
  },
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^26.8.1",
    "electron-installer-windows": "^3.0.0",
    "electron-packager": "^17.1.2"
  }
}
